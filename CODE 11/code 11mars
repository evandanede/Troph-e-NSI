<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<title>Cercle Montpellier - Running</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>
  body { margin: 0; }
  #map { height: 100vh; }

  /* --- HUD --- */
  #hud {
    position: fixed;
    top: 15px;
    left: 15px;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.55);
    color: white;
    padding: 12px 18px;
    border-radius: 12px;
    font-family: Arial, sans-serif;
    width: 220px;
    backdrop-filter: blur(4px);
  }

  #profile {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
  }

  #profile img {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid white;
    margin-right: 10px;
  }

  #profile .name {
    font-weight: bold;
    font-size: 15px;
  }

  #profile .level {
    font-size: 13px;
    opacity: 0.9;
  }

  #xpBarContainer {
    width: 100%;
    height: 8px;
    background: rgba(255,255,255,0.25);
    border-radius: 5px;
    margin-bottom: 12px;
  }

  #xpBar {
    height: 100%;
    width: 0%;
    background: #4caf50;
  }

  #startRaceBtn {
    position: fixed;
    left: 50%;
    bottom: 20px;
    transform: translateX(-50%);
    z-index: 1000;
    padding: 12px 22px;
    border: none;
    border-radius: 999px;
    background: #0b57d0;
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
  }
</style>
</head>
<body>

<!-- HUD -->
<div id="hud">
  <div id="profile">
    <img src="https://i.imgur.com/4ZQZ4ZC.png">
    <div>
      <div class="name">Ralph</div>
      <div class="level">Niveau <span id="level">1</span></div>
    </div>
  </div>

  <div id="xpBarContainer">
    <div id="xpBar"></div>
  </div>

  <p><strong>Distance :</strong> <span id="km">0.00</span> km</p>
  <p><strong>Zones prises :</strong> <span id="zones">0</span></p>
</div>

<div id="map"></div>

<button id="startRaceBtn">Lancer une course</button>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
  /* -----------------------------
     1. CARTE
  ----------------------------- */
  var map = L.map('map').setView([43.611, 3.877], 9);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

  /* -----------------------------
     2. HUD & NIVEAU
  ----------------------------- */
  let kmTotal = 0;
  let lastPos = null;

  let level = 1;
  let xp = 0;
  let xpMax = 5;   // 5 km par niveau

  let zones = 0;

  function updateHUD() {
    document.getElementById("km").textContent = kmTotal.toFixed(2);
    document.getElementById("zones").textContent = zones;

    xp = kmTotal;

    if (xp >= xpMax) {
      level++;
      xp = 0;
      kmTotal = 0;
      xpMax += 5;
      document.getElementById("level").textContent = level;
    }

    let percent = (xp / xpMax) * 100;
    document.getElementById("xpBar").style.width = percent + "%";
  }

  /* -----------------------------
     3. DISTANCE SIMPLE
  ----------------------------- */
  function dist(lat1, lon1, lat2, lon2) {
    const R = 6371;
    const x = (lat2 - lat1) * Math.PI / 180;
    const y = (lon2 - lon1) * Math.PI / 180;
    return R * Math.sqrt(x*x + y*y);
  }

  /* -----------------------------
     4. TRAÇÉ & ZONES
  ----------------------------- */
  let pathPoints = [];
  let pathLine = null;
  let pathColor = null;

  function randomColor() {
    return "#" + Math.floor(Math.random() * 16777215).toString(16);
  }

  function isLoopClosed() {
    if (pathPoints.length < 10) return false;
    let first = pathPoints[0];
    let last = pathPoints[pathPoints.length - 1];
    let d = dist(first.lat, first.lng, last.lat, last.lng);
    return d < 0.02; // ~20m
  }

  function fillCapturedZone() {
    L.polygon(pathPoints, {
      color: pathColor,
      fillColor: pathColor,
      fillOpacity: 0.35
    }).addTo(map);

    zones++;
    updateHUD();
  }

  /* -----------------------------
     5. POSITION UTILISATEUR
  ----------------------------- */
  var userMarker = null;
  var centered = false;
  var running = false;

  document.getElementById("startRaceBtn").onclick = function () {
    running = !running;
    this.textContent = running ? "Arrêter la course" : "Lancer une course";
    this.style.background = running ? "#c62828" : "#0b57d0";

    if (running) {
      pathPoints = [];
      pathLine = null;
      pathColor = randomColor();
    } else {
      lastPos = null;
    }
  };

  if (navigator.geolocation) {
    navigator.geolocation.watchPosition(
      pos => {
        let lat = pos.coords.latitude;
        let lng = pos.coords.longitude;

        if (!userMarker) {
          userMarker = L.circleMarker([lat, lng], {
            radius: 8,
            color: "white",
            fillColor: "#2d7ff9",
            fillOpacity: 1,
            weight: 2
          }).addTo(map);
        } else {
          userMarker.setLatLng([lat, lng]);
        }

        if (!centered) {
          map.setView([lat, lng], 18);
          centered = true;
        }

        if (running) {
          if (lastPos) {
            kmTotal += dist(lastPos.lat, lastPos.lng, lat, lng);
          }
          lastPos = { lat, lng };
          updateHUD();

          // Tracé
          pathPoints.push({ lat, lng });

          if (!pathLine) {
            pathLine = L.polyline([], { color: pathColor, weight: 4 }).addTo(map);
          }
          pathLine.setLatLngs(pathPoints);

          if (isLoopClosed()) {
            fillCapturedZone();
            pathPoints = [];
            pathLine = null;
            pathColor = randomColor();
          }
        }
      },
      () => alert("Impossible de récupérer la position."),
      { enableHighAccuracy: true }
    );
  } else {
    alert("La géolocalisation n'est pas supportée par ce navigateur.");
  }
</script>
</body>
</html>
